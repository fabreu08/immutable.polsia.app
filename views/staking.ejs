<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stake IQC — Immutable QC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    body { background: var(--bg); color: var(--fg); font-family: var(--font-body); }
    .page { max-width: 720px; margin: 0 auto; padding: 100px 40px 40px; }
    .page-title { font-family: var(--font-display); font-size: 2.5rem; margin-bottom: 8px; }
    .page-sub { color: var(--fg-muted); margin-bottom: 40px; }
    .staking-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 40px;
      margin-bottom: 32px;
    }
    .balance-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
    }
    .balance-row:last-child { border-bottom: none; }
    .balance-label { font-size: 0.875rem; color: var(--fg-muted); }
    .balance-value { font-family: var(--font-mono); font-size: 1.25rem; font-weight: 600; }
    .form-group { margin: 24px 0; }
    label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 8px; color: var(--fg); }
    input[type="number"] {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--fg);
      padding: 14px 18px;
      border-radius: 10px;
      font-family: var(--font-mono);
      font-size: 1.1rem;
      box-sizing: border-box;
    }
    input[type="number"]:focus { outline: none; border-color: var(--accent); }
    .btn-stake {
      width: 100%;
      padding: 16px;
      background: var(--accent);
      color: var(--bg);
      border: none;
      border-radius: 12px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 12px;
    }
    .btn-stake:hover { opacity: 0.9; }
    .btn-stake:disabled { opacity: 0.5; cursor: not-allowed; }
    .info-box {
      background: var(--accent-dim);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      font-size: 0.875rem;
      color: var(--fg-muted);
      margin-top: 32px;
    }
    .info-box strong { color: var(--fg); }
    .status { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); }
    .warning { color: #EAB308; font-size: 0.8rem; }
  </style>
</head>
<body>
  <%- include('partials/app-nav', { currentPath: typeof currentPath !== 'undefined' ? currentPath : '' }) %>

  <div class="page">
    <h1 class="page-title">Stake IQC</h1>
    <p class="page-sub">Stake tokens to participate as a validator and commit quality control data on-chain.</p>

    <div class="staking-card">
      <div class="balance-row">
        <div>
          <div class="balance-label">Your IQC Balance</div>
          <div class="balance-value" id="tokenBalance">—</div>
        </div>
        <div class="status" id="tokenBalanceStatus"></div>
      </div>

      <div class="balance-row">
        <div>
          <div class="balance-label">Currently Staked</div>
          <div class="balance-value" id="stakedBalance">—</div>
        </div>
        <div class="status" id="stakedBalanceStatus"></div>
      </div>

      <div class="form-group">
        <label for="stakeAmount">Amount to Stake</label>
        <input type="number" id="stakeAmount" value="5" step="0.1" min="0.1">
        <div class="hint">Minimum 1 IQC required to commit packets. You can stake more for future use.</div>
      </div>

      <button id="stakeBtn" class="btn-stake" onclick="handleStake()">Stake IQC</button>

      <div style="margin-top: 32px; border-top: 1px solid var(--border); padding-top: 24px;">
        <div class="form-group">
          <label for="unstakeAmount">Amount to Unstake</label>
          <input type="number" id="unstakeAmount" value="1" step="0.1" min="0.1">
        </div>
        <button onclick="handleUnstake()" style="width:100%; padding:14px; background:#EF4444; color:white; border:none; border-radius:10px; font-weight:600;">
          Unstake IQC
        </button>
      </div>

      <div id="stakeStatus" style="margin-top:12px; font-size:0.8rem; text-align:center; color:var(--fg-muted);"></div>
    </div>

    <div class="info-box">
      <strong>Important: How staking actually works</strong><br><br>
      <strong>1. Staking must go through the "Stake" button above.</strong><br>
      Simply sending IQC tokens directly to the Registry contract address <strong>does NOT</strong> increase your staked balance in the contract.<br><br>
      2. When you use the Stake button:<br>
      &nbsp;&nbsp;- It calls <code>approve()</code> on the IQC token<br>
      &nbsp;&nbsp;- Then calls <code>stake()</code> on the Registry<br>
      &nbsp;&nbsp;- This updates the internal <code>stakedBalance[yourAddress]</code> mapping<br><br>
      3. Only tokens recorded in that mapping can be used for <code>commitQCPacket</code>.<br><br>
      <strong>Unstaking:</strong> The currently deployed Registry does <strong>not</strong> have an <code>unstake()</code> function. Your staked tokens are locked until we deploy an upgraded version of the contract that supports unstaking.
    </div>

    <div class="info-box" style="margin-top: 16px; background: rgba(234,179,8,0.08); border-color: #EAB308;">
      <strong>Having trouble seeing your stake?</strong><br><br>
      If you previously sent tokens directly to the Registry address (instead of using the Stake button), they will appear in your token transfer history on Basescan, <strong>but they are not counted</strong> toward your usable stake for committing data.<br><br>
      Use the "Check any address" tool below to see the <strong>real</strong> amount recorded in the Registry contract.
    </div>

    <!-- Manual staked balance checker -->
    <div class="staking-card" style="margin-top: 24px;">
      <div style="font-weight:600; margin-bottom:12px;">Check real staked balance for any address</div>
      <div style="display:flex; gap:8px;">
        <input type="text" id="checkAddress" placeholder="0x..." value="0x36f374dbba8fd95b45dfd43ae4eaae3108fff929" style="flex:1; padding:10px; border-radius:8px; border:1px solid var(--border); font-family:monospace;">
        <button onclick="checkStakedBalance()" style="padding:10px 20px; border-radius:8px; background:var(--accent); color:white; border:none;">Check</button>
      </div>
      <div id="checkResult" style="margin-top:12px; font-family:monospace; font-size:0.95rem;"></div>
    </div>

    <div style="margin-top:40px; text-align:center; font-size:0.8rem; color:var(--fg-muted);">
      <strong>Active Registry (V2 - with unstaking):</strong><br>
      <a href="https://sepolia.basescan.org/address/0x80c00E40DF46E36652319662929a49bCaeBE52A3" target="_blank" style="color:var(--accent);">0x80c00E...52A3</a><br>
      Token: <a href="https://sepolia.basescan.org/address/0x6D3a4fb7D139d6bb2F241D7F5842955b9d747a4C" target="_blank" style="color:var(--accent);">0x6D3a4f...a4C</a>
    </div>

    <!-- Transaction History -->
    <div class="staking-card" style="margin-top: 32px;">
      <div style="font-weight:600; margin-bottom:16px; font-size:1.1rem;">Your Staking History</div>
      <button onclick="loadStakingHistory()" style="padding:8px 16px; margin-bottom:12px; border-radius:6px; background:var(--bg); border:1px solid var(--border); color:var(--fg);">
        Refresh History
      </button>
      <div id="historyList" style="font-family:monospace; font-size:0.85rem; line-height:1.5;"></div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.4/ethers.umd.min.js"></script>
  <script src="/js/wallet.js"></script>

  <script>
    // Registry addresses
    const OLD_REGISTRY = '0x35259312d419Fad651a376a737Cb1b5666602E9E';
    const REGISTRY_V2 = '0x80c00E40DF46E36652319662929a49bCaeBE52A3';
    const TOKEN_ADDRESS = '0x6D3a4fb7D139d6bb2F241D7F5842955b9d747a4C';
  </script>
  <script>
    async function updateBalances() {
      const state = IQC_WALLET.getState();
      const tokenEl = document.getElementById('tokenBalance');
      const stakedEl = document.getElementById('stakedBalance');

      if (!state.connected || !state.isIqcChain) {
        tokenEl.textContent = 'Connect wallet on Base Sepolia';
        stakedEl.textContent = '—';
        return;
      }

      try {
        const [tokenBal] = await Promise.all([
          IQC_WALLET.getIqcBalance()
        ]);

        // Force V2 staked balance (don't rely on potentially stale global wallet.js)
        const provider = new ethers.BrowserProvider(window.ethereum);
        const v2Registry = new ethers.Contract('0x80c00E40DF46E36652319662929a49bCaeBE52A3', [
          'function getStakedBalance(address) view returns (uint256)'
        ], provider);

        const v2Staked = await v2Registry.getStakedBalance(state.address);

        tokenEl.textContent = tokenBal ? parseFloat(tokenBal).toFixed(2) + ' IQC' : '—';
        stakedEl.textContent = ethers.formatUnits(v2Staked, 18) + ' IQC (V2)';

        if (v2Staked < ethers.parseUnits('1', 18)) {
          document.getElementById('stakedBalanceStatus').textContent = '⚠️ Too low to commit';
          document.getElementById('stakedBalanceStatus').style.color = '#EAB308';
        }
      } catch (e) {
        console.error(e);
        stakedEl.textContent = 'Error querying V2';
      }
    }

    async function handleStake() {
      const btn = document.getElementById('stakeBtn');
      const status = document.getElementById('stakeStatus');
      const amountInput = document.getElementById('stakeAmount');
      const amount = parseFloat(amountInput.value);

      if (!amount || amount <= 0) {
        status.textContent = 'Please enter a valid amount';
        status.style.color = '#EF4444';
        return;
      }

      const state = IQC_WALLET.getState();
      if (!state.connected || !state.isIqcChain) {
        status.textContent = 'Please connect your wallet on Base Sepolia';
        status.style.color = '#EF4444';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Staking...';
      status.textContent = 'Please confirm the two transactions in your wallet (Approve + Stake)';
      status.style.color = 'var(--fg-muted)';

      try {
        const provider = new ethers.BrowserProvider(window.ethereum);
        const signer = await provider.getSigner();

        const token = new ethers.Contract(TOKEN_ADDRESS, [
          'function approve(address spender, uint256 amount) returns (bool)'
        ], signer);

        const registry = new ethers.Contract(REGISTRY_V2, [
          'function stake(uint256 amount) external'
        ], signer);

        const amountWei = ethers.parseUnits(amount.toString(), 18);

        // Approve
        const approveTx = await token.approve(REGISTRY_V2, amountWei);
        await approveTx.wait();

        // Stake
        const stakeTx = await registry.stake(amountWei);
        await stakeTx.wait();

        status.textContent = `Successfully staked ${amount} IQC!`;
        status.style.color = 'var(--accent)';

        await updateBalances();

        setTimeout(() => {
          btn.disabled = false;
          btn.textContent = 'Stake IQC';
          status.textContent = '';
        }, 2500);
      } catch (err) {
        console.error(err);
        status.textContent = 'Stake failed: ' + (err.reason || err.message);
        status.style.color = '#EF4444';
        btn.disabled = false;
        btn.textContent = 'Stake IQC';
      }
    }

    // Auto-refresh balances when wallet state changes
    if (typeof IQC_WALLET !== 'undefined') {
      IQC_WALLET.onStateChange(() => {
        updateBalances();
      });
    }

    // Manual staked balance checker (works without connecting wallet)
    async function checkStakedBalance() {
      const addr = document.getElementById('checkAddress').value.trim();
      const resultEl = document.getElementById('checkResult');

      if (!addr || !addr.startsWith('0x') || addr.length !== 42) {
        resultEl.innerHTML = '<span style="color:#EF4444">Please enter a valid address</span>';
        return;
      }

      resultEl.innerHTML = 'Querying Registry contract...';

      try {
        const provider = new ethers.JsonRpcProvider('https://sepolia.base.org');

        const [oldStaked, v2Staked] = await Promise.all([
          new ethers.Contract(OLD_REGISTRY, ['function getStakedBalance(address) view returns (uint256)'], provider).getStakedBalance(addr),
          new ethers.Contract(REGISTRY_V2, ['function getStakedBalance(address) view returns (uint256)'], provider).getStakedBalance(addr)
        ]);

        const oldFmt = ethers.formatUnits(oldStaked, 18);
        const v2Fmt = ethers.formatUnits(v2Staked, 18);

        resultEl.innerHTML = `
          <strong>Old Registry:</strong> ${parseFloat(oldFmt).toFixed(2)} IQC<br>
          <strong>V2 Registry (current):</strong> <span style="color:var(--accent);">${parseFloat(v2Fmt).toFixed(2)} IQC</span>
        `;
      } catch (e) {
        console.error(e);
        resultEl.innerHTML = '<span style="color:#EF4444">Failed to query. Check the address or try again.</span>';
      }
    }

    async function handleUnstake() {
      const status = document.getElementById('stakeStatus');
      const amountInput = document.getElementById('unstakeAmount');
      const amount = parseFloat(amountInput.value);

      if (!amount || amount <= 0) {
        status.textContent = 'Please enter a valid amount';
        status.style.color = '#EF4444';
        return;
      }

      const state = IQC_WALLET.getState();
      if (!state.connected || !state.isIqcChain) {
        status.textContent = 'Please connect your wallet on Base Sepolia';
        status.style.color = '#EF4444';
        return;
      }

      status.textContent = 'Unstaking... Please confirm in wallet.';
      status.style.color = 'var(--fg-muted)';

      try {
        const provider = new ethers.BrowserProvider(window.ethereum);
        const signer = await provider.getSigner();

        const registryABI = [
          'function unstake(uint256 amount) external',
          'function getStakedBalance(address user) view returns (uint256)'
        ];

        const registry = new ethers.Contract(REGISTRY_V2, registryABI, signer);
        const tx = await registry.unstake(ethers.parseUnits(amount.toString(), 18));
        await tx.wait();

        status.textContent = `Successfully unstaked ${amount} IQC!`;
        status.style.color = '#10B981';

        await updateBalances();
        setTimeout(() => { status.textContent = ''; }, 3000);
      } catch (err) {
        console.error(err);
        status.textContent = 'Unstake failed: ' + (err.reason || err.message);
        status.style.color = '#EF4444';
      }
    }

    async function loadStakingHistory() {
      const state = IQC_WALLET.getState();
      const container = document.getElementById('historyList');

      if (!state.connected || !state.address) {
        container.innerHTML = '<span style="color:#EF4444">Connect wallet to view history</span>';
        return;
      }

      const addr = state.address.toLowerCase();
      container.innerHTML = 'Loading your wallet transaction history from Basescan (best method for older activity)...';

      try {
        // Use Basescan account API - far superior to block scanning for per-wallet history
        // Fetch more pages to catch older activity (25+ days old)
        let allTx = [];
        for (let page = 1; page <= 3; page++) {
          const url = `https://api-sepolia.basescan.org/api?module=account&action=txlist&address=${addr}&startblock=0&endblock=99999999&sort=desc&page=${page}&offset=100`;
          const res = await fetch(url);
          const data = await res.json();
          if (data.status === "1" && data.result?.length) {
            allTx = allTx.concat(data.result);
          } else {
            break;
          }
        }

        // Use the accumulated allTx from the pagination loop above
        const oldReg = OLD_REGISTRY.toLowerCase();
        const v2Reg = REGISTRY_V2.toLowerCase();

        const relevant = allTx.filter(tx => {
          const to = (tx.to || '').toLowerCase();
          const from = (tx.from || '').toLowerCase();
          return to === oldReg || to === v2Reg || from === oldReg || from === v2Reg;
        });

        if (relevant.length === 0) {
          container.innerHTML = `
            No contract calls to the Registries found in your recent txs.<br><br>
            <strong>Your current staked balances:</strong><br>
            Old Registry: 5009 IQC &nbsp;&nbsp;|&nbsp;&nbsp; V2 (active): 1466 IQC<br><br>
            <a href="https://sepolia.basescan.org/address/0x36f374dbba8fd95b45dfd43ae4eaae3108fff929#tokentxns" target="_blank" style="color:var(--accent);">
              View your actual token transfer history on Basescan →
            </a>
          `;
          return;
        }

        let html = '';
        for (const tx of relevant.slice(0, 30)) {
          const to = (tx.to || '').toLowerCase();
          const isV2 = to === v2Reg;
          const regLabel = isV2 ? 'V2' : 'Old';

          let action = tx.functionName || tx.methodId || 'Contract Interaction';
          let color = '#888';

          if (action.toLowerCase().includes('stake') && !action.toLowerCase().includes('un')) {
            color = '#10B981';
          } else if (action.toLowerCase().includes('unstake')) {
            color = '#EF4444';
          }

          const value = parseFloat(ethers.formatEther(tx.value || '0')).toFixed(4);
          const time = new Date(parseInt(tx.timeStamp) * 1000).toLocaleString();
          const txUrl = `https://sepolia.basescan.org/tx/${tx.hash}`;

          html += `
            <div style="margin-bottom:10px; padding:8px 0; border-bottom:1px solid #222;">
              <span style="color:${color}; font-weight:600;">${action}</span>
              <span style="font-size:0.65rem; background:#222; padding:0 4px; border-radius:2px;">${regLabel}</span><br>
              Value: <strong>${value} ETH</strong><br>
              <span style="color:#666; font-size:0.7rem;">${time}</span><br>
              <a href="${txUrl}" target="_blank" style="color:#888; font-size:0.7rem;">${tx.hash.slice(0,10)}...</a>
            </div>
          `;
        }

        container.innerHTML = html || 'No relevant transactions found.';
      } catch (e) {
        console.error('Basescan txlist error:', e);
        container.innerHTML = `
          Failed to load history from Basescan.<br>
          <button onclick="loadStakingHistory()" style="margin-top:8px; font-size:0.75rem;">Try again</button>
        `;
      }
    }

    async function safeQuery(contract, eventName, address, fromBlock, toBlock) {
      try {
        return await contract.queryFilter(contract.filters[eventName](address), fromBlock, toBlock);
      } catch (e) {
        console.warn(`Failed to fetch ${eventName} events:`, e.message);
        return [];
      }
    }

    // Load significantly older history (for users whose activity is old)
    async function loadOlderHistory() {
      const container = document.getElementById('historyList');
      container.innerHTML = 'Loading very old history... this may take 10–30 seconds.';

      try {
        const provider = new ethers.JsonRpcProvider('https://sepolia.base.org');
        const latestBlock = await provider.getBlockNumber();
        const fromBlock = 0; // full history

        // Reuse the same logic but with full range
        const registryABI = [
          'event Staked(address indexed user, uint256 amount)',
          'event Unstaked(address indexed user, uint256 amount)'
        ];

        const oldRegistry = new ethers.Contract(OLD_REGISTRY, registryABI, provider);
        const v2Registry = new ethers.Contract(REGISTRY_V2, registryABI, provider);

        const [oldStaked, oldUnstaked, v2Staked, v2Unstaked] = await Promise.all([
          safeQuery(oldRegistry, 'Staked', IQC_WALLET.getState().address, fromBlock, latestBlock),
          safeQuery(oldRegistry, 'Unstaked', IQC_WALLET.getState().address, fromBlock, latestBlock),
          safeQuery(v2Registry, 'Staked', IQC_WALLET.getState().address, fromBlock, latestBlock),
          safeQuery(v2Registry, 'Unstaked', IQC_WALLET.getState().address, fromBlock, latestBlock),
        ]);

        const allEvents = [
          ...oldStaked.map(e => ({ type: 'STAKE', registry: 'Old', ...e })),
          ...oldUnstaked.map(e => ({ type: 'UNSTAKE', registry: 'Old', ...e })),
          ...v2Staked.map(e => ({ type: 'STAKE', registry: 'V2', ...e })),
          ...v2Unstaked.map(e => ({ type: 'UNSTAKE', registry: 'V2', ...e }))
        ].sort((a, b) => b.blockNumber - a.blockNumber);

        if (allEvents.length === 0) {
          container.innerHTML = 'Still no events found. Your activity may not have gone through the official stake/unstake functions.';
          return;
        }

        let html = '';
        for (const event of allEvents) {
          const amount = ethers.formatUnits(event.args.amount, 18);
          const action = event.type === 'STAKE' ? 'Staked' : 'Unstaked';
          const color = event.type === 'STAKE' ? '#10B981' : '#EF4444';
          const txUrl = `https://sepolia.basescan.org/tx/${event.transactionHash}`;
          const regLabel = event.registry === 'V2' ? 'V2' : 'Old';

          html += `
            <div style="margin-bottom:8px; padding:6px 0; border-bottom:1px solid #222;">
              <span style="color:${color}; font-weight:600;">${action}</span> 
              <strong>${parseFloat(amount).toFixed(2)} IQC</strong>
              <span style="font-size:0.65rem; background:#222; padding:0 4px; border-radius:2px;">${regLabel}</span><br>
              <a href="${txUrl}" target="_blank" style="color:#888; font-size:0.7rem;">${event.transactionHash.slice(0,10)}...</a>
            </div>
          `;
        }
        container.innerHTML = html;
      } catch (e) {
        console.error(e);
        container.innerHTML = `
          <span style="color:#EF4444">Still failed to load very old history (RPC limits).</span><br>
          <small>Best solution: Use an Alchemy or Infura RPC URL with the staking page.</small>
        `;
      }
    }

    // Initial load
    document.addEventListener('DOMContentLoaded', () => {
      updateBalances();
      if (typeof IQC_WALLET !== 'undefined' && IQC_WALLET.isWalletAvailable()) {
        IQC_WALLET.connect().catch(() => {});
      }
    });
  </script>
</body>
</html>
