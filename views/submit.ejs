<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submit Reading — Immutable QC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    body { background: var(--bg); color: var(--fg); font-family: var(--font-body); }
    .page { max-width: 720px; margin: 0 auto; padding: 100px 40px 40px; }
    .page-title { font-family: var(--font-display); font-size: 2.5rem; margin-bottom: 8px; }
    .page-sub { color: var(--fg-muted); margin-bottom: 40px; }
    .form-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; }
    .form-group { margin-bottom: 24px; }
    label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 8px; color: var(--fg); }
    .label-hint { font-weight: 400; color: var(--fg-muted); font-size: 0.8125rem; margin-left: 8px; }
    input, select { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--fg); padding: 12px 16px; border-radius: 8px; font-family: var(--font-body); font-size: 1rem; box-sizing: border-box; }
    input:focus, select:focus { outline: none; border-color: var(--accent); }
    .btn { width: 100%; padding: 14px 24px; background: var(--accent); color: var(--bg); border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; font-family: var(--font-body); }
    .btn:hover { opacity: 0.9; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .result { margin-top: 24px; padding: 20px; border-radius: 12px; display: none; }
    .result.success { background: var(--accent-dim); border: 1px solid var(--border-strong); display: block; }
    .result.error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); display: block; }
    .result-title { font-size: 0.875rem; font-weight: 600; margin-bottom: 12px; font-family: var(--font-mono); }
    .result-row { display: flex; justify-content: space-between; font-size: 0.875rem; padding: 4px 0; border-bottom: 1px solid var(--border); }
    .result-row:last-child { border-bottom: none; }
    .result-label { color: var(--fg-muted); }
    .result-value { font-family: var(--font-mono); color: var(--fg); font-size: 0.8125rem; text-align: right; word-break: break-all; }
    .hint { font-size: 0.8125rem; color: var(--fg-muted); margin-top: 6px; }
    .simulator-hint { background: var(--accent-dim); border: 1px solid var(--border-strong); border-radius: 8px; padding: 16px; margin-bottom: 24px; font-size: 0.875rem; color: var(--fg-muted); }
    .simulator-hint strong { color: var(--accent); }
    .sensor-type-select { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 24px; }
    .sensor-type-btn { padding: 16px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; text-align: center; cursor: pointer; transition: all 0.2s; }
    .sensor-type-btn:hover { border-color: var(--border-strong); }
    .sensor-type-btn.selected { border-color: var(--accent); background: var(--accent-dim); }
    .sensor-type-btn input { display: none; }
    .sensor-type-name { font-size: 1rem; font-weight: 600; color: var(--fg); display: block; }
    .sensor-type-desc { font-size: 0.8125rem; color: var(--fg-muted); margin-top: 4px; display: block; }
    .tab-bar { display: flex; gap: 0; margin-bottom: 32px; border-bottom: 1px solid var(--border); }
    .tab-btn { padding: 12px 24px; background: none; border: none; border-bottom: 2px solid transparent; color: var(--fg-muted); font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: var(--font-body); transition: all 0.2s; }
    .tab-btn:hover { color: var(--fg); }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .file-drop { border: 2px dashed var(--border-strong); border-radius: 12px; padding: 48px 24px; text-align: center; cursor: pointer; transition: all 0.2s; background: var(--bg); }
    .file-drop:hover, .file-drop.drag-over { border-color: var(--accent); background: var(--accent-dim); }
    .file-drop-icon { font-size: 2rem; margin-bottom: 12px; }
    .file-drop-text { font-size: 0.875rem; color: var(--fg-muted); }
    .file-drop-text strong { color: var(--accent); }
    .file-name { font-family: var(--font-mono); font-size: 0.875rem; color: var(--fg); margin-top: 12px; }
    .format-badges { display: flex; gap: 8px; margin-top: 16px; justify-content: center; }
    .format-badge { font-size: 0.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; color: var(--fg-muted); font-family: var(--font-mono); }
    .peak-preview { margin-top: 16px; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; display: none; }
    .peak-preview-header { padding: 12px 16px; background: var(--accent-dim); font-size: 0.8125rem; font-weight: 600; border-bottom: 1px solid var(--border); color: var(--fg-muted); font-family: var(--font-mono); }
    .peak-preview-body { padding: 16px; }
    .peak-count { font-family: var(--font-mono); color: var(--accent); font-size: 1.25rem; }
  </style>
  <style>
    .faucet-banner { display:none; background: rgba(234,179,8,0.1); border: 1px solid rgba(234,179,8,0.4); border-radius: 8px; padding: 12px 16px; margin-top: 16px; font-size: 0.875rem; color: var(--fg-muted); }
    .faucet-banner.visible { display: flex; align-items: center; gap: 10px; }
    .faucet-banner .faucet-msg { flex: 1; }
    .faucet-banner .faucet-msg strong { color: #EAB308; }
    .btn-faucet { padding: 8px 16px; background: #EAB308; color: #000; border: none; border-radius: 6px; font-size: 0.8125rem; font-weight: 600; cursor: pointer; white-space: nowrap; font-family: var(--font-body); }
    .btn-faucet:hover { opacity: 0.85; }
    .btn-faucet:disabled { opacity: 0.5; cursor: not-allowed; }
    .submit-wrap { position: relative; }
    .low-balance-hint { display:none; font-size: 0.8125rem; color: #EAB308; margin-top: 8px; text-align: center; }
    .low-balance-hint.visible { display: block; }
    .tx-link { color: var(--accent); font-family: var(--font-mono); font-size: 0.8125rem; }
  </style>
</head>
<body>
  <%- include('partials/app-nav', { currentPath: typeof currentPath !== 'undefined' ? currentPath : '' }) %>

  <div class="page">
    <h1 class="page-title">Submit Reading</h1>
    <p class="page-sub">Capture and cryptographically sign instrument measurements</p>

    <!-- Quick staking panel (dedicated UX for task 4) -->
    <div style="max-width:720px; margin:0 auto 24px; background:var(--bg-card); border:1px solid var(--border); border-radius:12px; padding:16px 20px; font-size:0.875rem;">
      <strong>On-chain commits require staking.</strong> Connect your wallet and use the wallet menu (top right) → "Stake 5 IQC" or the button below if your staked balance is low.
      <button onclick="quickStakeFromPanel(this)" style="margin-left:12px; padding:4px 10px; font-size:0.75rem; background:#0a0a0a; border:1px solid var(--border); color:var(--accent); border-radius:6px; cursor:pointer;">Stake 5 IQC</button>
    </div>

    <div class="tab-bar">
      <button class="tab-btn active" onclick="switchTab('manual')">Manual Entry</button>
      <button class="tab-btn" onclick="switchTab('hplc')">Upload HPLC CSV</button>
    </div>

    <!-- ===== MANUAL ENTRY TAB ===== -->
    <div class="tab-panel active" id="tab-manual">
      <div class="simulator-hint">
        <strong>Demo Mode:</strong> This form simulates an instrument submitting a reading.
        In production, instruments call <code>POST /api/readings</code> directly.
      </div>

      <div style="background:#fee2e2; border:3px solid #dc2626; padding:12px 16px; border-radius:8px; margin-bottom:20px; font-size:0.9rem; font-weight:600; color:#991b1b;">
        ⚠️ ON-CHAIN COMMIT TARGET: V2 Registry<br>
        <span style="font-size:0.85rem; font-weight:400;">0x80c00E40DF46E36652319662929a49bCaeBE52A3</span><br>
        <span style="font-size:0.75rem; font-weight:400;">(This is where your 1466 IQC is currently staked)</span>
      </div>

      <div id="submitProgress" style="display:none; background:#f0f9ff; border:1px solid #0ea5e9; padding:10px 14px; border-radius:6px; margin-bottom:16px; font-size:0.85rem; color:#0369a1;">
        <!-- Dynamic progress messages will appear here -->
      </div>

      <div class="form-card">
        <form id="readingForm">
          <div class="form-group">
            <label>Sensor Type</label>
            <div class="sensor-type-select">
              <label class="sensor-type-btn selected" id="phBtn">
                <input type="radio" name="sensorType" value="ph" checked>
                <span class="sensor-type-name">pH Meter</span>
                <span class="sensor-type-desc">Laboratory probe</span>
              </label>
              <label class="sensor-type-btn" id="tempBtn">
                <input type="radio" name="sensorType" value="temperature">
                <span class="sensor-type-name">Temperature</span>
                <span class="sensor-type-desc">RTD / thermocouple</span>
              </label>
              <label class="sensor-type-btn" id="hplcBtn">
                <input type="radio" name="sensorType" value="hplc">
                <span class="sensor-type-name">HPLC</span>
                <span class="sensor-type-desc">Chromatograph</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label for="value">Measurement Value <span class="label-hint" id="unitHint">pH unit (0–14)</span></label>
            <input type="number" id="value" name="value" step="0.001" min="0" max="1000" placeholder="e.g. 7.045" required>
          </div>

          <div class="form-group">
            <label for="instrumentSerial">Instrument Serial</label>
            <select id="instrumentSerial" name="instrumentSerial" required>
              <option value="">Select instrument…</option>
              <option value="PH-2026-001">PH-2026-001 — pH Meter Alpha-1 (Lab A)</option>
              <option value="TEMP-2026-077">TEMP-2026-077 — Temperature Probe T-77 (Lab B)</option>
            </select>
            <div class="hint">HPLC instruments are auto-registered on upload</div>
          </div>

          <div class="form-group">
            <label for="capturedAt">Captured At <span class="label-hint">(leave blank for now)</span></label>
            <input type="datetime-local" id="capturedAt" name="capturedAt">
          </div>

          <div class="submit-wrap">
            <button type="submit" class="btn" id="submitBtn" style="display:flex;align-items:center;justify-content:center" data-track="manual-submit-reading">Sign &amp; Submit to Ledger</button>

          <button type="button" onclick="submitDbOnly(this)" 
                  style="width:100%; margin-top:8px; padding:10px; background:#0ea5e9; color:white; border:none; border-radius:8px; font-size:0.9rem;">
            Submit (Fast + Background Ledger)
          </button>
            <div class="faucet-banner" id="faucetBanner">
              <div class="faucet-msg">
                <strong>Low IQC balance</strong> — Request free test tokens to cover gas fees
              </div>
              <button class="btn-faucet" id="faucetBtn" onclick="handleFaucetRequest(event)">Request Test Tokens</button>
            </div>
            <div class="low-balance-hint" id="lowBalanceHint">Low IQC balance — <a href="#" onclick="handleFaucetRequest(event); return false;" style="color:var(--accent);">request test tokens</a></div>
          </div>
        </form>

        <div class="result" id="result"></div>
      </div>
    </div>

    <!-- ===== HPLC CSV UPLOAD TAB ===== -->
    <div class="tab-panel" id="tab-hplc">
      <div class="simulator-hint">
        <strong>HPLC CSV Import:</strong> Upload a Waters Empower or Agilent OpenLAB CSV export.
        Each peak row becomes a signed reading with its own QC packet.
      </div>

      <div class="form-card">
        <form id="hplcForm">
          <div class="form-group">
            <label>CSV File</label>
            <div class="file-drop" id="fileDrop" onclick="document.getElementById('csvFile').click()">
              <div class="file-drop-icon">📊</div>
              <div class="file-drop-text">Drop CSV here or <strong>browse</strong></div>
              <div class="file-name" id="fileName"></div>
              <div class="format-badges">
                <span class="format-badge">Waters Empower</span>
                <span class="format-badge">Agilent OpenLAB</span>
              </div>
            </div>
            <input type="file" id="csvFile" name="csv" accept=".csv" style="display:none" required>
            <div class="hint">Max 5 MB. Only Waters Empower and Agilent OpenLAB CSV exports supported.</div>
          </div>

          <div class="form-group">
            <label for="hplcSerial">Instrument Serial <span class="label-hint">(auto-registered if blank)</span></label>
            <input type="text" id="hplcSerial" name="instrumentSerial" placeholder="e.g. HPLC-2026-001">
          </div>

          <div class="form-group">
            <label for="batchId">Batch / Lot ID <span class="label-hint">(optional)</span></label>
            <input type="text" id="batchId" name="batchId" placeholder="e.g. LOT-2026-042">
          </div>

          <div class="form-group">
            <label for="injectionTime">Injection Time <span class="label-hint">(ISO 8601)</span></label>
            <input type="datetime-local" id="injectionTime" name="injectionTime">
            <div class="hint">Defaults to current time if not provided. All peaks share this timestamp.</div>
          </div>

          <div class="peak-preview" id="peakPreview">
            <div class="peak-preview-header">Peak preview</div>
            <div class="peak-preview-body" id="peakPreviewBody"></div>
          </div>

          <button type="submit" class="btn" id="hplcSubmitBtn" disabled data-track="hplc-upload-submit">Parse &amp; Ingest CSV</button>
        </form>

        <div class="result" id="hplcResult"></div>
      </div>
    </div>
  </div>

  <script src="/js/analytics.js"></script>
  <script>
    // Quick stake helper (used from submit result area)
    async function handleQuickStake(btnEl) {
      if (!IQC_WALLET || !IQC_WALLET.stake) {
        alert('Wallet module not ready');
        return;
      }
      btnEl.disabled = true;
      btnEl.textContent = 'Staking 5 IQC...';
      try {
        await IQC_WALLET.stake(5);
        btnEl.textContent = 'Stake successful!';
        setTimeout(() => {
          location.reload(); // simplest way to refresh balances
        }, 1200);
      } catch (err) {
        alert('Staking failed: ' + err.message);
        btnEl.disabled = false;
        btnEl.textContent = 'Stake 5 IQC Now';
      }
    }

    async function quickStakeFromPanel(btnEl) {
      if (!IQC_WALLET || !IQC_WALLET.stake) {
        alert('Wallet module not ready. Connect wallet first.');
        return;
      }
      btnEl.disabled = true;
      btnEl.textContent = 'Staking...';
      try {
        await IQC_WALLET.stake(5);
        btnEl.textContent = 'Done!';
        setTimeout(() => location.reload(), 900);
      } catch (err) {
        alert('Stake failed: ' + err.message);
        btnEl.disabled = false;
        btnEl.textContent = 'Stake 5 IQC';
      }
    }

    // Tab switching
    function switchTab(tab) {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.getElementById('tab-' + tab).classList.add('active');
      event.target.classList.add('active');
    }

    // Sensor type toggle
    document.querySelectorAll('.sensor-type-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sensor-type-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        const type = btn.querySelector('input').value;
        const unitHint = document.getElementById('unitHint');
        const valueInput = document.getElementById('value');
        if (type === 'ph') {
          unitHint.textContent = 'pH unit (0–14)';
          valueInput.max = '14'; valueInput.placeholder = 'e.g. 7.045';
        } else if (type === 'temperature') {
          unitHint.textContent = '°C';
          valueInput.max = '300'; valueInput.placeholder = 'e.g. 23.456';
        } else {
          unitHint.textContent = 'peak area (counts)';
          valueInput.max = '999999999'; valueInput.placeholder = 'e.g. 1547832';
        }
      });
    });

    // Fast DB-only submit (bypasses on-chain completely for reliability)
    window.submitDbOnly = async function(btnEl) {
      const form = document.getElementById('readingForm');
      const progress = document.getElementById('submitProgress');
      const result = document.getElementById('result');
      const submitBtn = document.getElementById('submitBtn');

      if (btnEl) btnEl.disabled = true;
      if (submitBtn) submitBtn.disabled = true;
      if (progress) {
        progress.style.display = 'block';
        progress.innerHTML = 'Saving to database only (fast mode)...';
      }

      const fd = new FormData(form);
      const payload = {
        sensorType: fd.get('sensorType'),
        value: parseFloat(fd.get('value')),
        unit: fd.get('sensorType') === 'ph' ? 'pH' : fd.get('sensorType') === 'temperature' ? '°C' : 'counts',
        instrumentSerial: fd.get('instrumentSerial'),
        capturedAt: fd.get('capturedAt') || new Date().toISOString(),
      };

      try {
        const res = await fetch('/api/readings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || 'Failed to save');
        }

        const data = await res.json();
        result.className = 'result success';
        result.innerHTML = `
          <div class="result-title">✓ Reading saved successfully</div>
          <div class="result-row"><span class="result-label">Reading ID</span><span class="result-value">#${data.reading?.id || 'N/A'}</span></div>
          <div style="margin-top:12px; font-size:0.8rem; color:#666;">
            Fast save complete. A ledger block is being created in the background. On-chain commit can be triggered later.
          </div>
        `;
      } catch (err) {
        result.className = 'result error';
        result.innerHTML = `<div class="result-title">✗ Error</div><div style="font-size:0.875rem;color:#EF4444;">${err.message}</div>`;
      } finally {
        if (btnEl) btnEl.disabled = false;
        if (submitBtn) submitBtn.disabled = false;
        if (progress) progress.style.display = 'none';
      }
    };

    // Manual form submission
    document.getElementById('readingForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      const result = document.getElementById('result');
      btn.disabled = true;
      result.className = 'result';
      result.style.display = 'none';

      // Step 1: Ensure wallet is connected before submitting
      const state = IQC_WALLET.getState();
      if (!state.connected) {
        if (!IQC_WALLET.isWalletAvailable()) {
          alert('No wallet detected. Please install MetaMask or an EVM wallet browser extension.');
          btn.disabled = false;
          return;
        }
        btn.textContent = 'Connecting wallet…';
        try {
          await IQC_WALLET.connect();
        } catch (err) {
          btn.textContent = 'Sign & Submit to Ledger';
          btn.disabled = false;
          result.className = 'result error';
          result.innerHTML = `<div class="result-title">✗ Wallet connection failed</div><div style="font-size:0.875rem;color:#EF4444;">${err.message}</div>`;
          return;
        }
      }

      // Step 2: Check IQC balance (show faucet if needed)
      btn.textContent = 'Signing…';
      const newState = IQC_WALLET.getState();
      if (newState.isIqcChain) {
        const balance = await IQC_WALLET.getIqcBalance();
        const balanceNum = parseFloat(balance) || 0;
        const banner = document.getElementById('faucetBanner');
        const hint = document.getElementById('lowBalanceHint');
        if (balanceNum < 0.001) {
          banner.classList.add('visible');
          hint.classList.add('visible');
        } else {
          banner.classList.remove('visible');
          hint.classList.remove('visible');
        }
      }

      const progress = document.getElementById('submitProgress');
      const showProgress = (msg) => {
        if (progress) {
          progress.style.display = 'block';
          progress.innerHTML = msg;
        }
      };

      try {
        const fd = new FormData(e.target);
        const payload = {
          sensorType: fd.get('sensorType'),
          value: parseFloat(fd.get('value')),
          unit: fd.get('sensorType') === 'ph' ? 'pH' : fd.get('sensorType') === 'temperature' ? '°C' : 'counts',
          instrumentSerial: fd.get('instrumentSerial'),
          capturedAt: fd.get('capturedAt') || new Date().toISOString(),
        };

        // === REAL SUBMISSION: Create actual reading + QC packet ===
        showProgress('Step 1/3: Saving reading to database...');
        btn.textContent = 'Saving reading...';

        // Add timeout so the UI doesn't appear completely stuck
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 12000); // 12 second timeout

        let readingRes;
        try {
          readingRes = await fetch('/api/readings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
            signal: controller.signal,
          });
        } catch (fetchErr) {
          clearTimeout(timeoutId);
          if (fetchErr.name === 'AbortError') {
            throw new Error('Request timed out after 12s. The database may still be processing. Try the "DB Only (Fast)" button below if available.');
          }
          throw fetchErr;
        }
        clearTimeout(timeoutId);

        if (!readingRes.ok) {
          const errData = await readingRes.json().catch(() => ({}));
          throw new Error(errData.error || 'Failed to save reading to ledger');
        }

        const realData = await readingRes.json();
        const data = {
          qcPacket: realData.qcPacket || { id: null, status: 'created' },
          reading: realData.reading,
          instrumentId: payload.instrumentSerial,
        };

        showProgress('Step 2/3: Reading saved to DB successfully. ' + (realData.note || ''));

        // Step 3: Trigger on-chain commitment via the real IQCRegistry
        const stateAfter = IQC_WALLET.getState();
        let attestationHtml = '';
        if (stateAfter.connected && stateAfter.isIqcChain) {
          btn.textContent = 'Checking stake...';

          // === Staking UX: Check V2 balance (user is actively using V2) ===
          let stakedBalance = '0';
          try {
            const provider = new ethers.BrowserProvider(window.ethereum);
            const registry = new ethers.Contract('0x80c00E40DF46E36652319662929a49bCaeBE52A3', [
              'function getStakedBalance(address) view returns (uint256)'
            ], provider);
            const bal = await registry.getStakedBalance(await (await provider.getSigner()).getAddress());
            stakedBalance = ethers.formatUnits(bal, 18);
          } catch (e) {
            console.warn('Could not read V2 staked balance', e);
          }

          const stakedNum = parseFloat(stakedBalance);
          if (stakedNum < 1) {
            btn.textContent = 'Stake required';
            result.className = 'result error';
            result.style.display = 'block';
            result.innerHTML = `
              <div class="result-title">⚠ Staking Required</div>
              <div style="font-size:0.875rem; margin-bottom:12px;">
                You need at least <strong>1 IQC staked</strong> in the Registry to commit packets on-chain.<br>
                Current staked: <strong>${stakedBalance} IQC</strong>
              </div>
              <button onclick="handleQuickStake(this)" style="padding:10px 16px; background:#EAB308; color:#000; border:none; border-radius:6px; font-weight:600; cursor:pointer;">
                Stake 5 IQC Now
              </button>
            `;
            btn.disabled = false;
            btn.textContent = 'Sign & Submit to Ledger';
            return;
          }

          showProgress('Step 3/3: Checking V2 stake and committing on-chain...');
          btn.textContent = 'Committing on-chain…';

          // Force on-chain commit to V2 (where user is actively staking)
          const V2_REGISTRY = '0x80c00E40DF46E36652319662929a49bCaeBE52A3';

          try {
            const provider = new ethers.BrowserProvider(window.ethereum);
            const signer = await provider.getSigner();

            const registry = new ethers.Contract(V2_REGISTRY, [
              'function commitQCPacket(string instrumentId, string dataHash) external',
              'function getStakedBalance(address) view returns (uint256)'
            ], signer);

            // Double-check stake on V2 before sending
            const currentStaked = await registry.getStakedBalance(await signer.getAddress());
            if (currentStaked < ethers.parseUnits('1', 18)) {
              throw new Error('Insufficient stake on V2 Registry. Please stake more on the /staking page first.');
            }

            showProgress('Step 3/3: Stake OK on V2. Sending commitQCPacket transaction...');

            const tx = await registry.commitQCPacket(data.instrumentId, data.reading.reading_hash);
            const receipt = await tx.wait();

            const explorerUrl = `https://sepolia.basescan.org/tx/${tx.hash}`;
            attestationHtml = `
              <div class="result-row"><span class="result-label">On-Chain TX (V2)</span><span class="result-value"><a href="${explorerUrl}" target="_blank" rel="noopener" style="color:var(--accent);">${tx.hash.substring(0, 20)}… ↗</a></span></div>
              <div class="result-row"><span class="result-label">Attestor</span><span class="result-value">${(await signer.getAddress()).slice(0,6)}...${(await signer.getAddress()).slice(-4)}</span></div>
              <div class="result-row"><span class="result-label">Instrument</span><span class="result-value">${data.instrumentId}</span></div>`;

            showProgress('✅ Everything done! DB saved + on-chain committed.');
          } catch (attErr) {
            console.warn('[submit] On-chain commit to V2 failed:', attErr.message);
            // Make the on-chain failure very loud and separate
            result.className = 'result error';
            result.innerHTML = `
              <div class="result-title">✓ Data saved to ledger (DB only)</div>
              <div style="margin:12px 0; padding:12px; background:#fee2e2; border:2px solid #dc2626; border-radius:6px; color:#991b1b;">
                <strong>⚠ On-chain commit to V2 failed</strong><br>
                ${attErr.message}<br><br>
                <small>The reading is safely recorded in the database. You can retry the on-chain part later from the Staking page once you have enough stake on V2.</small>
              </div>
            `;
            btn.disabled = false;
            btn.textContent = 'Sign & Submit to Ledger';
            return;
          }
        }

        result.className = 'result success';
        result.innerHTML = `
          <div class="result-title">✓ Reading committed to ledger</div>
          <div class="result-row"><span class="result-label">Reading ID</span><span class="result-value">#${data.reading.id}</span></div>
          <div class="result-row"><span class="result-label">Reading Hash</span><span class="result-value">${(data.reading.reading_hash || '').substring(0, 20)}…</span></div>
          <div class="result-row"><span class="result-label">QC Packet</span><span class="result-value">#${data.qcPacket.id} · ${data.qcPacket.status || 'pending'}</span></div>
          ${attestationHtml}
          <div style="margin-top:16px;text-align:center;">
            <a href="/readings" style="color:var(--accent);font-size:0.875rem;">View all readings →</a>
          </div>`;
      } catch (err) {
        result.className = 'result error';
        result.innerHTML = `<div class="result-title">✗ Error</div><div style="font-size:0.875rem;color:#EF4444;">${err.message}</div>`;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Sign & Submit to Ledger';
      }
    });

    // HPLC file selection & drag-drop
    const csvFile = document.getElementById('csvFile');
    const fileDrop = document.getElementById('fileDrop');
    const fileName = document.getElementById('fileName');
    const hplcSubmitBtn = document.getElementById('hplcSubmitBtn');
    const peakPreview = document.getElementById('peakPreview');
    const peakPreviewBody = document.getElementById('peakPreviewBody');

    csvFile.addEventListener('change', () => {
      if (csvFile.files.length > 0) {
        fileName.textContent = csvFile.files[0].name;
        hplcSubmitBtn.disabled = false;
        hplcSubmitBtn.textContent = 'Parse & Ingest CSV';
        // Quick preview: show file size
        peakPreview.style.display = 'block';
        peakPreviewBody.innerHTML = `<span class="peak-count">${csvFile.files[0].name}</span> — ${(csvFile.files[0].size / 1024).toFixed(1)} KB ready to parse`;
      }
    });

    // Drag-drop visual
    fileDrop.addEventListener('dragover', (e) => { e.preventDefault(); fileDrop.classList.add('drag-over'); });
    fileDrop.addEventListener('dragleave', () => fileDrop.classList.remove('drag-over'));
    fileDrop.addEventListener('drop', (e) => {
      e.preventDefault();
      fileDrop.classList.remove('drag-over');
      csvFile.files = e.dataTransfer.files;
      if (csvFile.files.length > 0) {
        fileName.textContent = csvFile.files[0].name;
        hplcSubmitBtn.disabled = false;
        hplcSubmitBtn.textContent = 'Parse & Ingest CSV';
        peakPreview.style.display = 'block';
        peakPreviewBody.innerHTML = `<span class="peak-count">${csvFile.files[0].name}</span> — ${(csvFile.files[0].size / 1024).toFixed(1)} KB ready to parse`;
      }
    });

    // HPLC form submission — reads file as base64, sends as JSON
    document.getElementById('hplcForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('hplcSubmitBtn');
      const result = document.getElementById('hplcResult');
      btn.disabled = true;
      btn.textContent = 'Parsing & signing peaks…';
      result.className = 'result';
      result.style.display = 'none';

      try {
        const fileInput = document.getElementById('csvFile');
        if (!fileInput.files.length) throw new Error('No file selected');

        const file = fileInput.files[0];
        const csvBase64 = await file.text().then(t => btoa(t));

        const fd = new FormData(e.target);
        const payload = {
          csv: csvBase64,
          instrumentSerial: fd.get('instrumentSerial') || undefined,
          batchId: fd.get('batchId') || undefined,
          injectionTime: fd.get('injectionTime') ? new Date(fd.get('injectionTime')).toISOString() : undefined,
        };

        const res = await fetch('/api/hplc/upload', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'HPLC upload failed');

        result.className = 'result success';
        const peaks = data.peaksProcessed;
        const firstRead = data.readings[0];
        result.innerHTML = `
          <div class="result-title">✓ ${peaks} HPLC peak${peaks > 1 ? 's' : ''} committed to ledger</div>
          <div class="result-row"><span class="result-label">Instrument</span><span class="result-value">${data.instrument.name}</span></div>
          <div class="result-row"><span class="result-label">Format</span><span class="result-value">${data.format}</span></div>
          <div class="result-row"><span class="result-label">Peaks Processed</span><span class="result-value">${peaks}</span></div>
          <div class="result-row"><span class="result-label">Blocks</span><span class="result-value">#${firstRead.reading.block_number}–${data.readings[data.readings.length-1].reading.block_number}</span></div>
          <div class="result-row"><span class="result-label">QC Packets</span><span class="result-value">${peaks} pending review</span></div>
          <div style="margin-top:16px;text-align:center;">
            <a href="/readings?sensor_type=hplc" style="color:var(--accent);font-size:0.875rem;">View HPLC readings →</a>
          </div>`;
      } catch (err) {
        result.className = 'result error';
        result.innerHTML = `<div class="result-title">✗ Error</div><div style="font-size:0.875rem;color:#EF4444;">${err.message}</div>`;
      } finally {
        btn.disabled = false;
        btn.textContent = 'Parse & Ingest CSV';
      }
    });

    // Faucet request handler
async function handleFaucetRequest(e) {
  e.preventDefault();
  const state = IQC_WALLET.getState();
  const address = state.connectedAddress || "";
  const subject = encodeURIComponent("Request Base Sepolia IQC Test Tokens");
  const body = encodeURIComponent(`Wallet: ${address}\n\nPlease send some test IQC tokens.`);
  window.location.href = `mailto:hi@immutableqc.com?subject=${subject}&body=${body}`;
}
</script>
</body>
</html>
